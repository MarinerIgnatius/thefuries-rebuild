---
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /**
   * If true, nav starts transparent and overlays the hero photo.
   * Used on home (and any other page with a full-bleed hero image).
   */
  transparentNav?: boolean;
}

const {
  title,
  description = 'The definitive archive of The Furies – Toronto\'s proto-gothic post-punk institution. Photos, history, interviews, and the full story of a scene that came before the name existed.',
  ogImage = '/images/the-furies-Toronto-proto-goth-underground_80s.jpg',
  transparentNav = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const bodyClass = transparentNav ? 'has-transparent-nav' : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(ogImage, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts (Wix-matched: Gloock display, Azeret Mono nav, Sono 200/400 body, Pirata One blackletter accent) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Gloock&family=Azeret+Mono:wght@400;500&family=Sono:wght@200;300;400&family=Pirata+One&display=swap"
    />
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="sr-only">Skip to main content</a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal (vanilla, no framework) -->
    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>

    <!-- Nav scroll behavior: hide on scroll-down past threshold, reappear on scroll-up. Nav stays transparent always. -->
    <script>
      (() => {
        const nav = document.querySelector('.site-nav');
        if (!nav) return;
        const HIDE_THRESHOLD = 120;
        let lastY = window.scrollY;
        let ticking = false;

        const update = () => {
          const y = window.scrollY;
          const goingDown = y > lastY;
          if (y > HIDE_THRESHOLD && goingDown && Math.abs(y - lastY) > 4) {
            nav.classList.add('is-hidden');
          } else if (!goingDown) {
            nav.classList.remove('is-hidden');
          }
          lastY = y;
          ticking = false;
        };

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        }, { passive: true });
      })();
    </script>
  </body>
</html>
