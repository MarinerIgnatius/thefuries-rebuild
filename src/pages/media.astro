---
import BaseLayout from '@layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const title = 'Media — Photos · Posters · Video | The Furies Archive';
const description = 'Photos, show posters, and video from The Furies — Toronto proto-goth post-punk, 1986–1996. The source material from the underground.';

// Discover all gallery images at build time from public/images
const imagesDir = path.join(process.cwd(), 'public', 'images');
let galleryFiles: string[] = [];
try {
  galleryFiles = fs
    .readdirSync(imagesDir)
    .filter((f) => /^2c9315_.*\.jpg$/i.test(f))
    .sort();
} catch {
  galleryFiles = [];
}

const gallery = galleryFiles.map((file, i) => ({
  src: `/images/${file}`,
  alt: `The Furies archive — Toronto proto-goth underground, image ${String(i + 1).padStart(2, '0')}`,
}));
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/the-furies-jeff_riley-Toronto-proto-goth-underground_80s.jpg"
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <img
      class="hero__bg"
      src="/images/the-furies-jeff_riley-Toronto-proto-goth-underground_80s.jpg"
      alt="Jeff Riley — The Furies, Toronto proto-goth underground, 1980s archive"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__content">
      <h1 class="hero__eyebrow" id="hero-heading">
        Media: Photos · Show Posters · Video — What Survived Before Digital
      </h1>
      <p class="hero__display">From the Archives. The Source Material.</p>
    </div>
  </section>

  <!-- ── Gallery ────────────────────────────────────────────────── -->
  <section class="section" aria-labelledby="gallery-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">The Archive</h1>
      <h2 id="gallery-heading" class="reveal" style="margin-bottom: 3rem;">
        Rolls of Film. Posters. Video Fragments.
      </h2>
    </div>

    {gallery.length > 0 ? (
      <div class="gallery reveal">
        {gallery.map(({ src, alt }) => (
          <div class="gallery__item">
            <img src={src} alt={alt} loading="lazy" decoding="async" />
          </div>
        ))}
      </div>
    ) : (
      <div class="container">
        <p class="reveal">Gallery loading — archive restoration in progress.</p>
      </div>
    )}
  </section>

  <hr />

  <!-- ── Next ────────────────────────────────────────────────────── -->
  <section class="section" aria-label="Continue">
    <div class="container" style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
      <a href="/scene" class="btn btn--accent">← The Scene</a>
      <a href="/afterlives" class="btn btn--accent">Afterlives →</a>
    </div>
  </section>

</BaseLayout>
