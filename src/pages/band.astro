---
import BaseLayout from '@layouts/BaseLayout.astro';

const title       = 'The Furies Archive: Origins, Formation, Debut, Active Years & Legacy';
const description = 'The complete history of The Furies — Toronto\'s proto-goth post-punk band, 1986–1996. Origins, formation, venues, the long decline, and lasting legacy.';

/**
 * Timeline entries. Body copy uses <strong> to bold the key
 * instrument / venue / listening-diet names — Wix parity.
 */
const timeline = [
  {
    heading: 'The Origins (1984–1986)',
    body: `Before The Furies existed as a band, the sound existed as an instinct. Between 1984 and 1986, Daniel Riley worked alone — a <strong>Tascam 4-track</strong>, a <strong>Yamaha DX7</strong> cutting cold crystalline tones and metallic bass, a <strong>Roland Juno-106</strong> delivering its icy atmospheric haze. Guitars, voice and synths run through Boss phase, distortion and digital delay. Raw, atmospheric tension — a sonic skeleton waiting for a body. The listening diet was uncompromising: <strong>Gary Numan, Psychic TV, Fad Gadget, Cabaret Voltaire, Tones on Tail</strong>.`,
  },
  {
    heading: 'Formation 1986',
    body: `The definitive lineup coalesced in 1986 — Riley, Mark Stewart, Jeff Riley, Barnes, and soon after Steve Lafourtune. What emerged was cold, brooding, and deliberately aggressive: jagged guitar rhythms over synthetic atmospherics, a sonic signature that would soon map Toronto's gothic trajectory. The basement experiments became a live force.`,
  },
  {
    heading: 'Twilight Zone Debut 1986',
    body: `The debut at the <strong>Twilight Zone</strong> — 185 Richmond St. W., home to one of the most advanced sound systems in the city — was a statement. The 80s club kids packed the floor in a lysergic haze, not unlike a pagan ceremony. A high-profile emergence that cemented The Furies immediately in Toronto's alternative history.`,
  },
  {
    heading: 'Active Years & Venues',
    body: `What followed was a decade of constant presence inside <strong>Little Gotham</strong> — the city's infamous subterranean world that rivalled London and Berlin. <strong>Lee's Palace, El Mocambo, The Rivoli</strong>, the <strong>Bovine Sex Club</strong>. They haunted <strong>Sanctuary, Catch 22, Death in the Underground</strong> — the concentrated cluster of venues on Queen West that earned the street its nickname. Packed rooms, every time.`,
  },
  {
    heading: 'Industry and Principle',
    body: `Approaches came from <strong>EMI</strong> and <strong>Warner</strong>. The band declined both. In a subculture that wore independence as a badge of honour, signing to a major wasn't ambition — it was capitulation. The Furies kept the work pure.`,
  },
  {
    heading: 'The Lasting Legacy',
    body: `<strong>BlogTO</strong> named them one of the top 10 Toronto goth bands of all time — "essential to fostering the goth movement and setting the tone for style." Cited in the Wikipedia history of Toronto's alternative scene. Documented by indie press, and the early <strong>MuchMusic–CityTV</strong> cultural machine. A decade-long reign. Uncompromised throughout.`,
  },
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/the-furies-Toronto-proto-goth-underground_80s.jpg"
>

  <!-- ─── Hero: magazine-split over full-bleed band photo ────────── -->
  <section class="band-hero" aria-labelledby="band-hero-heading">
    <img
      class="band-hero__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_80s.jpg"
      alt="The Furies performing live — Toronto, 1980s archive photograph"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="band-hero__overlay" aria-hidden="true"></div>

    <div class="container band-hero__eyebrow-wrap">
      <h1 class="band-hero__eyebrow" id="band-hero-heading">
        <strong>Band:</strong> The Furies — origins, formation, debut, active years and legacy
      </h1>
    </div>

    <div class="container band-hero__grid">
      <h2 class="band-hero__display">
        Toronto post-punk / proto-goth, 1986–1996.<br />
        <span class="accent">The defining years.</span>
      </h2>
      <div class="band-hero__lede">
        <p>
          The Furies emerged in Toronto in 1986, less as a debut than as a convergence with the city's darkening pulse. Post-punk tension, nocturnal glamour, and underground appetite were beginning to lock into a new shape, and The Furies arrived exactly at that hour.
        </p>
        <p style="margin-top: 1.25rem;">
          What followed was the band's defining decade: 1986 to 1996, when the sound cut deeper, the image grew sharper, and the live presence took on its own dangerous silhouette. This was the era of the foundational strike — where sound, shadow, and live volatility were engineered into a permanent legacy.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── NOW Magazine pull-quote (centered, raised surface) ───── -->
  <section class="section section--raised" aria-labelledby="now-heading">
    <div class="container pull-quote pull-quote--centered reveal">
      <p class="pull-quote__text" id="now-heading">
        "They started very late for a Wednesday night… They were told never to return: The bassist slugged the soundman."
      </p>
      <cite class="pull-quote__attribution">NOW Magazine — Blue Smith</cite>
    </div>
  </section>

  <!-- ─── Timeline header + list ──────────────────────────────── -->
  <section class="section" aria-labelledby="decline-heading">
    <div class="container">
      <h2 id="decline-heading" class="display display--centered reveal">
        The long decline:<br />
        A history <span class="accent">1986–1996</span>
      </h2>
      <hr class="display-rule reveal" />

      <div class="timeline reveal">
        {timeline.map(({ heading, body }) => (
          <article class="timeline__item">
            <h3 class="timeline__heading">{heading}</h3>
            <p class="timeline__body" set:html={body}></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Continue CTAs ───────────────────────────────────────── -->
  <section class="section" aria-label="Continue">
    <div class="container band-continue">
      <a href="/scene"      class="btn btn--accent">The Scene</a>
      <a href="/media"      class="btn btn--accent">Archive Media</a>
      <a href="/afterlives" class="btn btn--accent">Afterlives</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Band hero (full-bleed photo + magazine split over it) ── */
  .band-hero {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow: hidden;
    padding-block: clamp(5rem, 12vh, 9rem);
  }

  .band-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .band-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 45%, rgba(0,0,0,0.75) 100%);
  }

  .band-hero__eyebrow-wrap { margin-bottom: clamp(2rem, 5vh, 4rem); }

  .band-hero__eyebrow {
    font-family: var(--font-eyebrow);
    font-size: var(--size-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    line-height: 1.45;
    text-transform: uppercase;
    color: var(--color-text-muted);
    max-width: 32ch;
  }

  .band-hero__eyebrow strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .band-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .band-hero__display {
    font-family: var(--font-display);
    font-size: var(--size-display);
    line-height: 0.95;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-text);
    max-width: 12ch;
  }

  .band-hero__display .accent { color: var(--color-accent); }

  .band-hero__lede p {
    font-family: var(--font-body);
    font-weight: var(--weight-body);
    font-size: var(--size-body-lg);
    line-height: 1.45;
    color: var(--color-text-muted);
    max-width: 38ch;
  }

  @media (max-width: 900px) {
    .band-hero__grid { grid-template-columns: 1fr; }
    .band-hero__display { max-width: none; }
  }

  /* ─── Pull-quote centered variant ─── */
  .pull-quote--centered { text-align: center; }
  .pull-quote--centered .pull-quote__text { max-width: none; margin-inline: auto; }
  .pull-quote--centered .pull-quote__attribution {
    text-align: center;
  }

  /* ─── Centered display with rule underneath ─── */
  .display--centered {
    text-align: center;
    max-width: none;
    margin-inline: auto;
  }

  .display-rule {
    border-top: 1px solid var(--color-text-subtle);
    max-width: 80%;
    margin: 2.5rem auto clamp(3rem, 7vw, 5rem);
  }

  /* ─── Timeline list ─── */
  .timeline {
    max-width: 72rem;
    margin-inline: auto;
  }

  .timeline__item {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline__item:last-child { border-bottom: none; }

  .timeline__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .timeline__body {
    font-family: var(--font-body);
    font-weight: var(--weight-body);
    font-size: var(--size-body-lg);
    line-height: 1.55;
    letter-spacing: 0;
    color: var(--color-text-muted);
    max-width: 66ch;
  }

  .timeline__body strong {
    color: var(--color-text);
    font-weight: 400;
  }

  /* ─── Continue CTAs ─── */
  .band-continue {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
