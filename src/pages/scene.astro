---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Toronto Underground Little Gotham 1986–1996 | The Furies Archive';
const description = 'The scene that birthed The Furies — Little Gotham, Toronto\'s proto-goth underground 1986–1996. Venues, DJs, the Shadow Circuit, and the city that came before the name existed.';

const venues = [
  { name: 'The Empire / Klub Domino', addr: 'Queen St W', status: 'defunct', desc: 'Early proto-goth flashpoint. Tuesday-night residencies for the scene\'s founding DJs.' },
  { name: 'The Twilight Zone', addr: '185 Richmond St W', status: 'defunct', desc: 'Home to one of the most advanced sound systems in the city. Sanctuary for the gloom-heavy elite. Backroom treated as avant-garde salon where the mainstream was strictly forbidden.' },
  { name: 'RPM Club', addr: 'Polson St (lakefront)', status: 'defunct', desc: 'Mid-sized shadow-circuit anchor. Peak-era slot for The Sisters of Mercy, Siouxsie, Killing Joke, and the Toronto bands that orbited them.' },
  { name: 'Sanctuary — Vampire Sex Bar', addr: 'Queen St E', status: 'active', desc: 'Still open. A coffin-booth institution that outlived the scene it was built for. Weekly goth night since 1993.' },
  { name: 'The Rivoli', addr: '334 Queen St W', status: 'active', desc: 'Literary-leaning basement. The final Furies show closed here, February 1996.' },
  { name: 'The Big Bop / Kathedral', addr: '651 Queen St W', status: 'defunct', desc: 'Three-story gargoyle mansion at Queen and Bathurst. Splintered-wood aesthetic where punk, goth, and industrial acts dominated three levels simultaneously.' },
  { name: 'The Horseshoe Tavern', addr: '370 Queen St W', status: 'active', desc: 'Jagged soul of the Queen West scene. Proving ground for the Positive Punk explosion. Same boards as Bauhaus, The Stranglers, Blondie.' },
  { name: 'Catch 22', addr: '379 Adelaide St W', status: 'defunct', desc: 'Cavern of strobe lights and steel; high-priestess for early-90s EBM. Industrial sanctuary under owner Pat Violo. Regular haunt for visiting industrial royalty.' },
  { name: 'Bovine Sex Club', addr: '542 Queen St W', status: 'active', desc: 'Junk-art baroque. Opened \'91 as the Shadow Circuit transitioned into its most aggressive gear. Magnetic retreat for visiting industrial elite during the Downward Spiral era.' },
  { name: 'The Slither Club', addr: '322 Richmond St W', status: 'defunct', desc: 'Oil-slicked basement of The Generator. Epicenter for the mechanical industrial-noise movement — dark, claustrophobic bunker.' },
  { name: 'The Night Gallery', addr: 'Yonge St', status: 'defunct', desc: 'Short-lived but scene-defining deathrock room above a shuttered newsstand.' },
  { name: 'Nuts & Bolts', addr: 'Queen St W', status: 'defunct', desc: 'Warehouse party series that presaged the modern underground rave circuit.' },
];

const djs = [
  { name: 'Die J! Mars', detail: 'Imported hard-EBM from the "Secret Doctors of Rhythm." Catch 22 resident.' },
  { name: 'Ivan Palmer', detail: 'Deathrock and dark-gothic originator. Empire / Klub Domino Tuesday nights, 1987–1991.' },
  { name: 'DJ Lazarus', detail: 'Ethereal / coldwave specialist. Weekly residency at Sanctuary.' },
  { name: 'DJ Michael X', detail: 'Hard-industrial counterpart to Die J! Mars. Broke Front 242, KMFDM, Skinny Puppy imports early.' },
  { name: 'Siobhan O\'Flynn', detail: 'Ethereal / 4AD aesthetic. Rivoli late-night sets.' },
  { name: 'DJ Shannon', detail: 'Post-punk historian. Bridged deathrock with early goth-rock.' },
  { name: 'Martin Streek', detail: 'Cross-scene connector; CFNY-FM alignment brought underground selections to broadcast.' },
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/scene.jpg"
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <img
      class="hero__bg"
      src="/images/scene.jpg"
      alt="Little Gotham — Toronto underground scene, 1986–1996"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__content">
      <h1 class="hero__eyebrow" id="hero-heading">
        Scene: Toronto Underground — Little Gotham 1986–1996
      </h1>
      <p class="hero__display">Little Gotham. The Shadow Circuit.</p>
    </div>
  </section>

  <!-- ── Little Gotham ──────────────────────────────────────────── -->
  <section class="section" aria-labelledby="lg-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">Little Gotham</h1>
      <div class="split reveal">
        <div class="split__text">
          <h2 id="lg-heading">Toronto 1986–1996</h2>
          <p style="margin-top: 2rem;">
            In the mid-1980s, a specific high-decibel gloom settled over Toronto, earning the city a moniker that would define its subterranean identity for decades: Little Gotham. While the rest of North America drowned in pastel excess, Toronto was building a fortress of black lace, industrial concrete, and synthetic isolation — one of the most concentrated alternative hubs on the planet, rivalling London and Berlin in tribal commitment.
          </p>
          <p style="margin-top: 1rem;">
            The Moderns of Yonge Street and the Freaks of Queen West ran months ahead of the global curve, moving to post-punk and cold-wave before the genres had names. For The Cure, Sisters of Mercy, Siouxsie, Bauhaus, and Killing Joke, Toronto wasn't just another tour date — it was a homecoming.
          </p>
        </div>
        <div class="split__media">
          <div class="media-panel">
            <img
              src="/images/bathroom_edited.jpg"
              alt="Little Gotham — Toronto underground interior, 1980s–1990s"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr />

  <!-- ── Bathroom pullquote ─────────────────────────────────────── -->
  <section class="section section--raised" aria-labelledby="bathroom-heading">
    <div class="container pull-quote reveal">
      <p class="pull-quote__text" id="bathroom-heading">
        The Audiences Were Discerning, Monochromatic, and Massive.
      </p>
      <cite class="pull-quote__attribution">The Furies Archive — Scene Oral History</cite>
    </div>
  </section>

  <hr />

  <!-- ── The Shadow Circuit ─────────────────────────────────────── -->
  <section class="section" aria-labelledby="circuit-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">The Shadow Circuit</h1>
      <h2 id="circuit-heading" class="reveal">The Venues: The Nocturnal Habitat of The Furies.</h2>

      <div class="reveal" style="margin-top: 3rem;">
        {venues.map(({ name, addr, status, desc }) => (
          <div class="entry-row">
            <div>
              <div class="entry-row__name">
                {name}
                <span class="entry-row__status">{status}</span>
              </div>
              <div class="entry-row__detail" style="margin-top: 0.5rem;">{addr}</div>
            </div>
            <div>
              <p>{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr />

  <!-- ── The Sonic Architects ───────────────────────────────────── -->
  <section class="section section--raised" aria-labelledby="djs-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">The Sonic Architects</h1>
      <h2 id="djs-heading" class="reveal">The DJs who built the nocturnal geometry.</h2>

      <div class="reveal" style="margin-top: 3rem;">
        {djs.map(({ name, detail }) => (
          <div class="entry-row">
            <div>
              <div class="entry-row__name">{name}</div>
            </div>
            <div>
              <p>{detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr />

  <!-- ── Next ────────────────────────────────────────────────────── -->
  <section class="section" aria-label="Continue">
    <div class="container" style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
      <a href="/band" class="btn btn--accent">← The Band</a>
      <a href="/media" class="btn btn--accent">Archive Media →</a>
    </div>
  </section>

</BaseLayout>
