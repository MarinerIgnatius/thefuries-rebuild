---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Connect | The Furies Archive — Share your photos and stories';
const description = 'Connect with The Furies Archive. Share your photos, video, and stories from Toronto\'s proto-goth underground 1986–1996 to help preserve the scene.';
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/BG_Daniel_5.jpg"
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <img
      class="hero__bg"
      src="/images/BG_Daniel_5.jpg"
      alt="The Furies — connect with the archive, Toronto proto-goth underground"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__content">
      <h1 class="hero__eyebrow" id="hero-heading">
        Connect: The Furies Archive. Share your photos, video and stories to help archive it.
      </h1>
      <p class="hero__display">Preserving the Noise. Expanding the Archive.</p>
    </div>
  </section>

  <!-- ── 01 Band Archive ───────────────────────────────────────── -->
  <section class="section" aria-labelledby="band-archive-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">01 · Band Archive</h1>
      <div class="reveal" style="max-width: 65ch;">
        <h2 id="band-archive-heading">Rolls of film. Cassettes. Flyers.</h2>
        <p style="margin-top: 2rem;">
          If you photographed, filmed, or recorded The Furies live — if you saved a flyer, a poster, a set-list, a cassette — the archive wants what you have. Scans, uploads, or originals for digitizing.
        </p>
        <a href="mailto:thefuries1986@gmail.com?subject=Band%20Archive%20Contribution" class="btn btn--accent" style="margin-top: 2.5rem;">
          Send to thefuries1986@gmail.com
        </a>
      </div>
    </div>
  </section>

  <hr />

  <!-- ── 02 Scene Front Lines ──────────────────────────────────── -->
  <section class="section section--raised" aria-labelledby="scene-lines-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">02 · Scene Front Lines</h1>
      <div class="reveal" style="max-width: 65ch;">
        <h2 id="scene-lines-heading">Were you at the Twilight Zone, Catch 22, Sanctuary?</h2>
        <p style="margin-top: 2rem;">
          Venue photos, backroom portraits, DJ-booth footage, crowd shots, fashion. The scene lived in analog — we're restoring it one contribution at a time.
        </p>
        <a href="mailto:thefuries1986@gmail.com?subject=Scene%20Archive%20Contribution" class="btn btn--accent" style="margin-top: 2.5rem;">
          Contribute scene material
        </a>
      </div>
    </div>
  </section>

  <hr />

  <!-- ── 03 Open Signal ────────────────────────────────────────── -->
  <section class="section" aria-labelledby="signal-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">03 · Open Signal</h1>
      <div class="reveal" style="max-width: 65ch;">
        <h2 id="signal-heading">Press. Licensing. Research. Interviews.</h2>
        <p style="margin-top: 2rem;">
          For press inquiries, sync-licensing requests, academic research, or interview scheduling — use the channel below. Responses typically within 72 hours.
        </p>
        <a href="mailto:thefuries1986@gmail.com" class="btn btn--accent" style="margin-top: 2.5rem;">
          thefuries1986@gmail.com
        </a>
      </div>
    </div>
  </section>

  <hr />

  <!-- ── Grit pullquote ─────────────────────────────────────────── -->
  <section class="section section--raised" aria-labelledby="grit-heading">
    <div class="container pull-quote reveal">
      <p class="pull-quote__text" id="grit-heading">
        Grit from the Original Underground.
      </p>
      <cite class="pull-quote__attribution">A Staple of the Goth Nightclub Circuit</cite>
    </div>
  </section>

</BaseLayout>
