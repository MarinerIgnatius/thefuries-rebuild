---
import BaseLayout from '@layouts/BaseLayout.astro';

const title       = 'The Furies Archive | Toronto Proto-Goth Post-Punk 1986–1996';
const description = 'The definitive archive of The Furies — Toronto\'s proto-gothic post-punk institution. Photos, history, interviews, and the full story of a scene that came before the name existed.';

// ─── Wix-verbatim copy ───────────────────────────────────────────────
// Scene + Media share the same body paragraph on Wix (editorial duplicate).
const sceneMediaBody = `The Furies didn't appear in isolation. They were a byproduct of a city's hardening edges — a collision of Queen Street's basement economies, the subcultural drift of the disenfranchised, and the predatory glamour of a scene refining its instincts in the dark. To understand the band is to navigate the geography of that transition: the nights where Toronto's underground finally found its pulse.`;
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/the-furies-Toronto-proto-goth-underground_80s.jpg"
  transparentNav={true}
>

  <!-- ─── Hero: full-bleed photo, eyebrow only ─────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <img
      class="hero__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_80s.jpg"
      alt="The Furies — Toronto proto-goth underground, 1986–1996"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="container hero__content">
      <h1 class="hero__eyebrow" id="hero-heading">
        <strong>Entry:</strong> Toronto proto-goth
      </h1>
    </div>
  </section>

  <!-- ─── BlogTO quote: flat dark, centered ────────────────────── -->
  <section class="quote-section" aria-labelledby="blogto-heading">
    <div class="container quote-section__inner">
      <h2 class="quote-display" id="blogto-heading">
        "Essential to Fostering the Goth Movement and Setting the Tone for <span class="accent">Style, Sound and Subversion."</span>
      </h2>
      <p class="quote-attr">BlogTO — Top 10 Toronto Goth Bands</p>
    </div>
  </section>

  <!-- ─── Band teaser: display LEFT, body+cta RIGHT ──────────────── -->
  <section class="teaser teaser--band" aria-labelledby="band-heading">
    <img
      class="teaser__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_Daniel_Riley.jpg"
      alt="Daniel Riley — The Furies, Toronto proto-goth underground"
      loading="lazy"
      decoding="async"
    />
    <p class="teaser__eyebrow"><strong>Band:</strong> The Furies Story</p>
    <div class="container teaser__grid">
      <div class="teaser__left">
        <h2 id="band-heading" class="teaser__display">
          Proto-Gothic Originators.<br />
          <span class="accent">40 Years Before Their Time.</span>
        </h2>
      </div>

      <div class="teaser__right">
        <div class="teaser__copy-block">
          <p class="teaser__body">
            Originating at the exact flashpoint where Toronto's post-punk scene darkened into goth, The Furies provided the early pulse for an underground movement that soon gained global significance.
          </p>
          <a href="/band" class="btn btn--accent teaser__cta">The Band</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Scene teaser: body+cta LEFT (right-aligned block), display RIGHT -->
  <section class="teaser teaser--scene" aria-labelledby="scene-heading">
    <img
      class="teaser__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_Jeff_Riley.jpg"
      alt="Jeff Riley — The Furies, Toronto proto-goth underground"
      loading="lazy"
      decoding="async"
    />
    <p class="teaser__eyebrow"><strong>Scene:</strong> Little Gotham</p>
    <div class="container teaser__grid">
      <div class="teaser__left teaser__left--end">
        <div class="teaser__copy-block">
          <p class="teaser__body teaser__body--end">{sceneMediaBody}</p>
          <a href="/scene" class="btn btn--accent teaser__cta">The Scene</a>
        </div>
      </div>

      <div class="teaser__right teaser__right--end">
        <h2 id="scene-heading" class="teaser__display teaser__display--end">
          The Scene.<br />
          The Sound.<br />
          <span class="accent">The Subversion.</span>
        </h2>
      </div>
    </div>
  </section>

  <!-- ─── Media teaser: display LEFT, body+cta RIGHT ──── -->
  <section class="teaser teaser--media" aria-labelledby="media-heading">
    <img
      class="teaser__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_Mark_Stewart.jpg"
      alt="Mark Stewart — The Furies, Toronto proto-goth underground"
      loading="lazy"
      decoding="async"
    />
    <p class="teaser__eyebrow"><strong>Media:</strong> Images - Show Posters - Video</p>
    <div class="container teaser__grid">
      <div class="teaser__left">
        <h2 id="media-heading" class="teaser__display">
          From the Archives.<br />
          <span class="accent">The Source Material.</span>
        </h2>
      </div>

      <div class="teaser__right">
        <div class="teaser__copy-block">
          <p class="teaser__body">{sceneMediaBody}</p>
          <a href="/media" class="btn btn--accent teaser__cta">Media</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Afterlives teaser: body+cta LEFT (right-aligned block), display RIGHT -->
  <section class="teaser teaser--afterlives" aria-labelledby="afterlives-heading">
    <img
      class="teaser__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_Steve_Lafourtune.jpg"
      alt="Steve Lafourtune — The Furies, Toronto proto-goth underground"
      loading="lazy"
      decoding="async"
    />
    <p class="teaser__eyebrow"><strong>Scene:</strong> Afterlives</p>
    <div class="container teaser__grid">
      <div class="teaser__left teaser__left--end">
        <div class="teaser__copy-block">
          <p class="teaser__body teaser__body--end">
            The decade didn't simply end; it fractured. From the dissolution of the core lineup came a series of new trajectories — parallel projects and sonic departures that carried the band's original friction into new spaces. These are the offshoots of the 1986–1996 run: the next movements for those who were there.
          </p>
          <a href="/afterlives" class="btn btn--accent teaser__cta">Afterlives</a>
        </div>
      </div>

      <div class="teaser__right teaser__right--end">
        <h2 id="afterlives-heading" class="teaser__display teaser__display--end">
          Afterlives.<br />
          <span class="accent">Lineage &amp; Legacy</span>
        </h2>
      </div>
    </div>
  </section>

  <!-- ─── Merch: body+cta LEFT (right-aligned block), display RIGHT — no eyebrow -->
  <section class="teaser teaser--merch" aria-label="Support the archive">
    <img
      class="teaser__bg"
      src="/images/merch.jpg"
      alt="The Furies merch — archive restoration support"
      loading="lazy"
      decoding="async"
    />
    <div class="container teaser__grid">
      <div class="teaser__left teaser__left--end">
        <div class="teaser__copy-block">
          <p class="teaser__body teaser__body--end">
            The Furies Archive is a labor of restoration — a digital deep-dive into ten years of Toronto darkwave history. Every purchase in this shop goes directly toward hosting costs, film digitizing, and the ongoing preservation of the 1986–1996 legacy. Wear the grit, support the history.
          </p>
          <a
            href="https://thefuries1986-shop.fourthwall.com"
            class="btn btn--accent teaser__cta"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get Merch
          </a>
        </div>
      </div>

      <div class="teaser__right teaser__right--end">
        <h2 class="teaser__display teaser__display--end">
          Grit from the Original&nbsp;&nbsp;<span class="accent">Underground</span>
        </h2>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero (full-bleed photo, just eyebrow) ─────────────────── */
  .hero {
    position: relative;
    isolation: isolate;
    /* v7: +35% height (was 36 / 100 / 68) */
    min-height: clamp(48.6rem, 135svh, 91.8rem);
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    background: var(--color-bg);
  }

  /* Hero container uses --page-gutter so eyebrow lines up with section eyebrows */
  .hero > .container {
    max-width: none;
    padding-inline: var(--page-gutter);
    position: relative;
    width: 100%;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
  }

  /* v7: Hero eyebrow pinned 100px from top, 11pt — matches teaser eyebrows */
  .hero__eyebrow {
    position: absolute;
    top: 100px;
    left: 0;
    right: 0;
    padding-inline: var(--page-gutter);
    margin: 0;
    font-family: var(--font-eyebrow);
    font-size: 11pt;
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    line-height: 1.45;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;             /* keep "ENTRY: TORONTO PROTO-GOTH" on one line */
  }
  @media (max-width: 480px) {
    .hero__eyebrow { white-space: normal; }
  }

  .hero__eyebrow strong {
    color: var(--color-text);
    font-weight: 500;
  }

  /* ─── BlogTO centered quote section ─────────────────────────── */
  .quote-section {
    background: #1a1a1a;                /* dark grey per Wix (not pure black) */
    padding-block: clamp(7rem, 18vh, 14rem);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(36rem, 90svh, 60rem);
  }

  .quote-section__inner { text-align: center; }

  .quote-display {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 6.6rem);
    line-height: 1.05;
    color: var(--color-text);
    max-width: 22ch;
    margin-inline: auto;
    text-align: center;
  }

  .quote-display .accent { color: var(--color-accent); }

  .quote-attr {
    margin-top: clamp(2rem, 5vh, 4rem);
    font-family: var(--font-eyebrow);
    font-size: var(--size-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    line-height: 1.45;
    text-transform: uppercase;
    color: var(--color-text);
    text-align: center;
  }

  /* ─── Teaser sections (shared layout) ───────────────────────── */
  .teaser {
    position: relative;
    isolation: isolate;
    background: var(--color-bg);
    overflow: hidden;
    /* v7: +35% height vs v6 (was 48rem / 110svh / 72rem) */
    min-height: clamp(64.8rem, 148svh, 97.2rem);
    display: flex;
    align-items: center;
    padding-block: clamp(5.4rem, 12vh, 10.8rem);
  }

  .teaser__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
  }

  /* 30% black overlay on every section bg image — hero stays clean */
  .teaser::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(0, 0, 0, 0.30);
    pointer-events: none;
  }

  /* Afterlives: mirror flip the keyboardist photo per Wix */
  .teaser--afterlives .teaser__bg { transform: scaleX(-1); }

  /* Eyebrow: pinned 100px from top of section, small (11pt) per design directive */
  .teaser__eyebrow {
    position: absolute;
    top: 100px;
    left: 0;
    right: 0;
    padding-inline: var(--page-gutter);
    z-index: 2;
    font-family: var(--font-eyebrow);
    font-size: 11pt;             /* explicit point size per design directive */
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    line-height: 1.45;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .teaser__eyebrow strong {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Push grid content edge-to-edge — override .container max-width inside teasers
     Uses --page-gutter (shared with .site-nav) so body content lines up under
     the nav icon on the left and under the link strip on the right. */
  .teaser > .container {
    max-width: none;
    padding-inline: var(--page-gutter);
  }

  .teaser__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas: "left right";
    column-gap: clamp(3rem, 7vw, 9rem);
    width: 100%;
    align-items: center;
  }

  .teaser__left  { grid-area: left; }
  .teaser__right { grid-area: right; }

  .teaser__display {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 6.6rem);
    line-height: 1.0;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-text);
    margin: 0;
  }

  .teaser__display .accent { color: var(--color-accent); }
  .teaser__display--end { text-align: right; }

  /* Body+CTA wrapper — caps width AND owns the left edge that the CTA aligns to */
  .teaser__copy-block {
    max-width: 56ch;
    margin-left: auto;          /* push block to right edge of its column */
  }
  /* When body sits in LEFT column (Scene/Afterlives/Merch), the body text is
     right-aligned but the BLOCK still hugs the right edge of column 1 */

  .teaser__body {
    font-family: var(--font-body);
    font-weight: var(--weight-body);
    font-size: var(--size-body-lg);
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0;
  }

  .teaser__body--end { text-align: right; }

  /* CTA button left-justified to the body block's left edge (per design directive) */
  .teaser__cta {
    display: inline-block;
    margin-top: clamp(2rem, 5vh, 3.5rem);
  }

  /* ─── Responsive collapse ───────────────────────────────────── */
  @media (max-width: 900px) {
    .teaser {
      /* +35% mobile height (was 40 / 90 / 60) */
      min-height: clamp(54rem, 121svh, 81rem);
    }
    .teaser__grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "left"
        "right";
      row-gap: clamp(2rem, 5vh, 3.5rem);
    }

    .teaser__display,
    .teaser__display--end,
    .teaser__body,
    .teaser__body--end {
      text-align: left;
      margin-left: 0;
    }

    .teaser__copy-block { margin-left: 0; }

    .teaser__bg { opacity: 0.55; }
  }
</style>
