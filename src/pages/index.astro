---
import BaseLayout from '@layouts/BaseLayout.astro';

const title       = 'The Furies Archive | Toronto Proto-Goth Post-Punk 1986–1996';
const description = 'The definitive archive of The Furies — Toronto\'s proto-gothic post-punk institution. Photos, history, interviews, and the full story of a scene that came before the name existed.';
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/images/the-furies-Toronto-proto-goth-underground_80s.jpg"
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <img
      class="hero__bg"
      src="/images/the-furies-Toronto-proto-goth-underground_80s.jpg"
      alt="The Furies — Toronto proto-goth underground, 1986–1996"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__content">
      <h1 class="hero__eyebrow" id="hero-heading">Entry: Toronto Proto-Goth</h1>
    </div>
  </section>

  <!-- ─── BlogTO headline pullquote ─────────────────────────────── -->
  <section class="section" aria-labelledby="blogto-heading">
    <div class="container pull-quote reveal">
      <p class="pull-quote__text" id="blogto-heading">
        Essential to Fostering the Goth Movement and Setting the Tone for <span class="accent">Style, Sound and Subversion.</span>
      </p>
      <cite class="pull-quote__attribution">BlogTO — Top 10 Toronto Goth Bands</cite>
    </div>
  </section>

  <hr />

  <!-- ─── Band teaser ───────────────────────────────────────────── -->
  <section class="section" aria-labelledby="band-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">Band: The Furies Story</h1>
      <div class="split reveal">
        <div class="split__text">
          <h2 id="band-heading" class="display">
            Proto-Gothic Originators.<br />
            <span class="accent">40 Years Before Their Time.</span>
          </h2>
          <p class="p--lg" style="margin-top: 2.25rem;">
            Originating at the exact flashpoint where Toronto's post-punk scene darkened into goth, The Furies provided the early pulse for an underground movement that soon gained global significance.
          </p>
          <a href="/band" class="btn btn--accent" style="margin-top: 2.5rem;">The Band</a>
        </div>
        <div class="split__media">
          <div class="media-panel media-panel--tall">
            <img
              src="/images/the-furies-Toronto-proto-goth-underground_Daniel_Riley.jpg"
              alt="Daniel Riley — The Furies, Toronto proto-goth underground"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr />

  <!-- ─── Scene teaser ──────────────────────────────────────────── -->
  <section class="section" aria-labelledby="scene-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">Scene: Little Gotham</h1>
      <div class="split split--text-left reveal">
        <div class="split__text">
          <h2 id="scene-heading" class="display">
            The Scene.<br />
            The Sound.<br />
            <span class="accent">The Subversion.</span>
          </h2>
          <p class="p--lg" style="margin-top: 2.25rem;">
            In the mid-1980s, a specific high-decibel gloom settled over Toronto, earning the city a moniker that would define its subterranean identity for decades: Little Gotham. One of the most concentrated alternative hubs on the planet — rivalling London and Berlin in tribal commitment.
          </p>
          <a href="/scene" class="btn btn--accent" style="margin-top: 2.5rem;">The Scene</a>
        </div>
        <div class="split__media">
          <div class="media-panel media-panel--tall">
            <img
              src="/images/scene.jpg"
              alt="Little Gotham — Toronto underground alternative scene, 1986–1996"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr />

  <!-- ─── Media / Archive teaser ───────────────────────────────── -->
  <section class="section" aria-labelledby="media-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">Media: Images · Show Posters · Video</h1>
      <div class="split reveal">
        <div class="split__text">
          <h2 id="media-heading" class="display">
            From the Archives.<br />
            <span class="accent">The Source Material.</span>
          </h2>
          <p class="p--lg" style="margin-top: 2.25rem;">
            Photos, posters, flyers, and video fragments salvaged from ten years of underground Toronto. The archive is a live restoration — film digitized, negatives scanned, posters indexed.
          </p>
          <a href="/media" class="btn btn--accent" style="margin-top: 2.5rem;">Media</a>
        </div>
        <div class="split__media">
          <div class="media-panel media-panel--tall">
            <img
              src="/images/the-furies-jeff_riley-Toronto-proto-goth-underground_80s.jpg"
              alt="Jeff Riley — The Furies, Toronto proto-goth underground, 1980s archive photo"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr />

  <!-- ─── Afterlives teaser ────────────────────────────────────── -->
  <section class="section" aria-labelledby="afterlives-heading">
    <div class="container">
      <h1 class="section-eyebrow reveal">Scene: Afterlives</h1>
      <div class="split split--text-left reveal">
        <div class="split__text">
          <p class="p--lg">
            The decade didn't simply end; it fractured. The players fanned out across Toronto's darkwave lineage: Sylvania, Millionaires, Fleurs Du Mal. Collaborations with Mars Roberge, Rob Sanzo, Steve Leckie, Jennifer Swain.
          </p>
          <h2 id="afterlives-heading" class="display" style="margin-top: 2.25rem;">
            Afterlives.<br />
            <span class="accent">Lineage &amp; Legacy.</span>
          </h2>
          <a href="/afterlives" class="btn btn--accent" style="margin-top: 2.5rem;">Afterlives</a>
        </div>
        <div class="split__media">
          <div class="media-panel media-panel--tall">
            <img
              src="/images/Sylvania_Band_Darkwave_Toronto.jpg"
              alt="Sylvania — Toronto darkwave, post-Furies lineage"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr />

  <!-- ─── Merch / Support the Work ─────────────────────────────── -->
  <section class="section" aria-label="Support the archive">
    <div class="container">
      <div class="merch-cta reveal">
        <div>
          <p>
            The Furies Archive is a labor of restoration — a digital deep-dive into ten years of Toronto darkwave history. Every purchase in this shop goes directly toward hosting costs, film digitizing, and the ongoing preservation of the 1986–1996 legacy. Wear the grit, support the history.
          </p>
        </div>
        <div>
          <h2 class="display display--tight">
            Grit from <em>the</em> Original<br />
            <span class="accent">Underground.</span>
          </h2>
          <a
            href="https://thefuries1986-shop.fourthwall.com"
            class="btn btn--accent"
            style="margin-top: 2.5rem;"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get Merch
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
