---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found | The Furies Archive">
  <section class="section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="container">
      <h1 class="section-eyebrow">404</h1>
      <h2 style="margin-bottom: 1.5rem;">Page Not Found.</h2>
      <p style="margin-bottom: 2.5rem; max-width: 52ch;">
        This page dissolved into the underground. The archive may have moved, renamed, or simply never existed.
      </p>
      <a href="/" class="btn btn--accent">← Return to Entry</a>
    </div>
  </section>
</BaseLayout>
