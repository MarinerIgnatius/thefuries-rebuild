---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found | The Furies Archive">
  <section class="section" style="min-height:60vh; display:flex; align-items:center;">
    <div class="container">
      <span class="section-label">404</span>
      <h1 style="margin-bottom:1rem;">Page Not Found</h1>
      <p style="color:var(--mid); margin-bottom:2rem;">
        This page dissolved into the underground.
      </p>
      <a href="/" class="btn btn--accent">← Return to Entry</a>
    </div>
  </section>
</BaseLayout>
