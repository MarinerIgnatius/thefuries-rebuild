---

<footer class="site-footer" role="contentinfo">
  <div class="container site-footer__inner">
    <a href="/" class="site-footer__brand" aria-label="The Furies Archive — home">
      <img
        src="/images/The_Furies_Band_Logo.png"
        alt="The Furies"
        width="220"
        height="135"
        loading="lazy"
        decoding="async"
      />
    </a>

    <ul class="site-footer__socials" role="list">
      {socials.map(({ href, label, svg }) => (
        <li>
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
          >
            <Fragment set:html={svg} />
          </a>
        </li>
      ))}
    </ul>

    <ul class="site-footer__links" role="list">
      <li>
        <a
          href="https://thefuries1986-shop.fourthwall.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Merch
        </a>
      </li>
      <li><a href="mailto:thefuries1986@gmail.com">Contact</a></li>
      <li><a href="/connect">Connect</a></li>
    </ul>

    <p class="site-footer__copy">
      © {year} The Furies Archive. Toronto Proto-Gothic Post-Punk 1986–1996. All rights reserved. Archive restoration project ongoing.
    </p>
  </div>
</footer>
